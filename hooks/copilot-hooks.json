{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "node \"${PLUGIN_ROOT}/hooks/2b-activate.js\"",
        "powershell": "node \"${PLUGIN_ROOT}\\hooks\\2b-activate.js\"",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "node \"${PLUGIN_ROOT}/hooks/2b-command.js\"",
        "powershell": "node \"${PLUGIN_ROOT}\\hooks\\2b-command.js\"",
        "timeoutSec": 5
      }
    ]
  }
}
